<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="CheckHelper.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:CheckHelper"
    xmlns:pages="clr-namespace:CheckHelper.Pages"
    Title="CheckHelper">

    <TabBar>
        <ShellContent
            Title="校验助手"
            Icon="dotnet_bot.png"
            ContentTemplate="{DataTemplate pages:CheckHelper}"
            Route="CheckHelper" />

        <ShellContent
            Title="串口调试助手"
            Icon="dotnet_bot.png"
            ContentTemplate="{DataTemplate pages:SerialPortPage}"
            Route="SerialPortPage" />

        <ShellContent
            Title="网络调试助手"
            Icon="dotnet_bot.png"
            ContentTemplate="{DataTemplate pages:NetworkDebugPage}"
            Route="NetworkDebugPage" />
    </TabBar>

</Shell>
